<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="hello-root"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.randexgen.swe1_randexgen.controller.helloViewController"
            stylesheets="@styles3.css">

    <center>
        <StackPane>
            <children>

                <VBox alignment="CENTER"
                      spacing="28.0">
                    <padding>
                        <Insets top="50.0" right="30.0" bottom="50.0" left="30.0"/>
                    </padding>

                    <!-- Title area -->
                    <VBox alignment="CENTER"
                          spacing="8.0">
                        <children>
                            <Label text="Welcome to RandExGen"
                                   styleClass="hello-title"/>

                            <Label text="Create or load an XML file to get started."
                                   wrapText="true"
                                   maxWidth="560.0"
                                   alignment="CENTER"
                                   styleClass="hello-subtitle"/>
                        </children>
                    </VBox>

                    <!-- Center card -->
                    <VBox alignment="CENTER"
                          spacing="26.0"
                          maxWidth="620.0"
                          prefWidth="620.0"
                          styleClass="hello-card">

                        <!-- Create -->
                        <VBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Button alignment="CENTER"
                                        onAction="#createXmlFile"
                                        prefHeight="50.0"
                                        prefWidth="210.0"
                                        styleClass="start-button"
                                        text="Create XML File">
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                    <graphic>
                                        <ImageView fitHeight="36.0"
                                                   fitWidth="43.0"
                                                   pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../images/image1.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Button>

                                <Label text="Start from scratch and create a new XML file for your exam data."
                                       wrapText="true"
                                       maxWidth="420.0"
                                       alignment="CENTER"
                                       styleClass="hello-description"/>
                            </children>
                        </VBox>

                        <!-- Divider -->
                        <HBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Region prefWidth="120.0"
                                        minHeight="1.0"
                                        prefHeight="1.0"
                                        maxHeight="1.0"
                                        styleClass="hello-divider"/>

                                <Label text="or"
                                       styleClass="hello-or-label"/>

                                <Region prefWidth="120.0"
                                        minHeight="1.0"
                                        prefHeight="1.0"
                                        maxHeight="1.0"
                                        styleClass="hello-divider"/>
                            </children>
                        </HBox>

                        <!-- Load -->
                        <VBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Button alignment="CENTER"
                                        onAction="#chooseFile"
                                        prefHeight="50.0"
                                        prefWidth="210.0"
                                        styleClass="start-button"
                                        text="Load XML File">
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                    <graphic>
                                        <ImageView fitHeight="36.0"
                                                   fitWidth="43.0"
                                                   pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../images/image2.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Button>

                                <Label text="Load an existing XML file to continue working on your exam."
                                       styleClass="hello-description"/>
                            </children>
                        </VBox>
                    </VBox>

                    <Label fx:id="welcomeText"
                           styleClass="hello-status-label"/>
                </VBox>

            </children>
        </StackPane>
    </center>

</BorderPane>