<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane style="-fx-background-color: #efefef;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.randexgen.swe1_randexgen.controller.helloViewController"
            stylesheets="@styles3.css">

    <!-- ===== TOP: Header mit XML / PDF Tabs ===== -->
    <top>
        <Pane prefHeight="26.0"
              style="-fx-background-color: #828282;">
            <children>
                <Pane prefHeight="26.0"
                      prefWidth="200.0"
                      style="-fx-background-color: #828282;">
                    <children>

                        <!-- XML Tab aktiv -->
                        <Pane prefHeight="26.0"
                              prefWidth="94.0"
                              style="-fx-background-color: #ddded4; -fx-background-radius: 8 8 0 0;">
                            <children>
                                <Text layoutX="36.0"
                                      layoutY="18.0"
                                      text="XML">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Text>
                            </children>
                        </Pane>

                        <!-- PDF Tab -->
                        <Pane fx:id="pdfPane"
                              layoutX="100.0"
                              prefHeight="26.0"
                              prefWidth="94.0"
                              onMouseClicked="#handlePdfClick"
                              style="-fx-background-color: #a3a69c; -fx-cursor: hand; -fx-background-radius: 8 8 0 0;">
                            <children>
                                <Text layoutX="36.0"
                                      layoutY="18.0"
                                      text="PDF">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Text>
                            </children>
                        </Pane>

                    </children>
                </Pane>
            </children>
        </Pane>
    </top>

    <!-- ===== CENTER: Moderner Startscreen ===== -->
    <center>
        <StackPane>
            <children>

                <VBox alignment="CENTER"
                      spacing="28.0">
                    <padding>
                        <Insets top="50.0" right="30.0" bottom="50.0" left="30.0" />
                    </padding>

                    <!-- Titelbereich -->
                    <VBox alignment="CENTER"
                          spacing="8.0">
                        <children>
                            <Label text="Welcome to RandExGen"
                                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #1f1f1f;" />

                            <Label text="Create or load an XML file to get started."
                                   wrapText="true"
                                   maxWidth="560.0"
                                   alignment="CENTER"
                                   style="-fx-font-size: 14; -fx-text-fill: #666666;" />
                        </children>
                    </VBox>

                    <!-- Zentrale Card -->
                    <VBox alignment="CENTER"
                          spacing="26.0"
                          maxWidth="620.0"
                          prefWidth="620.0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 24;
                                 -fx-border-color: #dddddd;
                                 -fx-border-radius: 24;
                                 -fx-padding: 34 36 34 36;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 18, 0.15, 0, 3);">

                        <!-- Create -->
                        <VBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Button alignment="CENTER"
                                        onAction="#createXmlFile"
                                        prefHeight="50.0"
                                        prefWidth="210.0"
                                        styleClass="start-button"
                                        text="Create XML File">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                    <graphic>
                                        <ImageView fitHeight="36.0"
                                                   fitWidth="43.0"
                                                   pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../images/image1.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Button>

                                <Label text="Start from scratch and create a new XML file for your exam data."
                                       wrapText="true"
                                       maxWidth="420.0"
                                       alignment="CENTER"
                                       style="-fx-font-size: 13; -fx-text-fill: #6f6f6f;" />
                            </children>
                        </VBox>

                        <!-- Trennung -->
                        <HBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Region prefWidth="120.0"
                                        style="-fx-background-color: #e2e2e2;"
                                        minHeight="1.0"
                                        prefHeight="1.0"
                                        maxHeight="1.0" />
                                <Label text="or"
                                       style="-fx-font-size: 15; -fx-text-fill: #7a7a7a; -fx-font-weight: bold;" />
                                <Region prefWidth="120.0"
                                        style="-fx-background-color: #e2e2e2;"
                                        minHeight="1.0"
                                        prefHeight="1.0"
                                        maxHeight="1.0" />
                            </children>
                        </HBox>

                        <!-- Load -->
                        <VBox alignment="CENTER"
                              spacing="12.0">
                            <children>
                                <Button alignment="CENTER"
                                        onAction="#chooseFile"
                                        prefHeight="50.0"
                                        prefWidth="210.0"
                                        styleClass="start-button"
                                        text="Load XML File">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                    <graphic>
                                        <ImageView fitHeight="36.0"
                                                   fitWidth="43.0"
                                                   pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../images/image2.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Button>

                                <Label text="Load an existing XML file to continue working on your exam."
                                       style="-fx-font-size: 13; -fx-text-fill: #666666;" />
                            </children>
                        </VBox>
                    </VBox>

                    <Label fx:id="welcomeText"
                           style="-fx-text-fill: #666666; -fx-font-size: 13;" />
                </VBox>

            </children>
        </StackPane>
    </center>

</BorderPane>