        <chapter id="ch-01">
            <title>Assembler Grundlagen</title>
            <examAppearance>INCLUDE</examAppearance>
            <selectedRegularScore>3.0</selectedRegularScore>
            <subtasks>
                <subtask id="st-01">
                    <title>Register Basics Regular Easy</title>
                    <score>1.0</score>
                    <difficultyLevel>EASY</difficultyLevel>
                    <examType>REGULAR</examType>
                    <variants>
                        <variant id="var-01">
                            <taskText>Nennen Sie zwei Register einer CPU.</taskText>
                            <answerText></answerText>
                            <solutionText>Register sind kleine, schnelle Speicher in der CPU.</solutionText>
                        </variant>
                        <variant id="var-02">
                            <taskText>Was ist ein Register im Prozessor?</taskText>
                            <answerText>Ein sehr schneller Speicherplatz in der CPU.</answerText>
                            <solutionText>Register speichern Operanden und Zwischenergebnisse.</solutionText>
                        </variant>
                    </variants>
                </subtask>
                <subtask id="st-02">
                    <title>Register Basics Regular Medium</title>
                    <score>1.0</score>
                    <difficultyLevel>MEDIUM</difficultyLevel>
                    <examType>REGULAR</examType>
                    <variants>
                        <variant id="var-03">
                            <taskText>Erklären Sie den Unterschied zwischen Datenregister und Adressregister.</taskText>
                            <answerText></answerText>
                            <solutionText>Beide Registerarten haben unterschiedliche Aufgaben im Befehlsablauf.</solutionText>
                        </variant>
                    </variants>
                </subtask>
                <subtask id="st-03">
                    <title>Register Basics Regular Hard</title>
                    <score>1.0</score>
                    <difficultyLevel>HARD</difficultyLevel>
                    <examType>REGULAR</examType>
                    <variants>
                        <variant id="var-04">
                            <taskText>Warum sind Registerzugriffe deutlich schneller als Speicherzugriffe?</taskText>
                            <answerText></answerText>
                            <solutionText>Der Zugriff auf Register benötigt weniger Takte als Hauptspeicherzugriffe.</solutionText>
                        </variant>
                    </variants>
                </subtask>
                <subtask id="st-04">
                    <title>Register Basics Practice Easy</title>
                    <score>2.0</score>
                    <difficultyLevel>MEDIUM</difficultyLevel>
                    <examType>REGULAR</examType>
                    <variants>
                        <variant id="v1">
                            <taskText></taskText>
                            <answerText></answerText>
                            <solutionText></solutionText>
                        </variant>
                        <variant id="v2">
                            <taskText></taskText>
                            <answerText></answerText>
                            <solutionText></solutionText>
                        </variant>
                    </variants>
                </subtask>
                <subtask id="st-05">
                    <title>Register Basics Practice Medium</title>
                    <score>2.0</score>
                    <difficultyLevel>MEDIUM</difficultyLevel>
                    <examType>PRACTICE</examType>
                    <variants>
                        <variant id="var-06">
                            <taskText>Erklären Sie kurz den Zweck eines Befehlszählers.</taskText>
                            <answerText></answerText>
                            <solutionText>Der Program Counter steuert die Reihenfolge der Befehlsausführung.</solutionText>
                        </variant>
                    </variants>
                </subtask>
                <subtask id="st-06">
                    <title>Register Basics Practice Hard</title>
                    <score>2.0</score>
                    <difficultyLevel>HARD</difficultyLevel>
                    <examType>PRACTICE</examType>
                    <variants>
                        <variant id="var-07">
                            <taskText>Warum ist Adressierung zentral für Assemblerprogramme?</taskText>
                            <answerText></answerText>
                            <solutionText>Ohne Adressierung können Operanden nicht sauber gelesen oder geschrieben werden.</solutionText>
                        </variant>
                    </variants>
                </subtask>
            </subtasks>
